{
  "schema_version": 2,
  "entry_model": {
    "public_entry_skill": "rdc-debugger",
    "panel_state_source": "workspace/cases/<case_id>/runs/<run_id>/notes/hypothesis_board.yaml"
  },
  "runtime_artifact_contract": {
    "run_root_layout": "workspace/cases/<case_id>/runs/<run_id>",
    "adapter_readiness_contract": "common/config/adapter_readiness.json",
    "required_case_files": [
      "workspace/cases/<case_id>/case.yaml",
      "workspace/cases/<case_id>/artifacts/entry_gate.yaml"
    ],
    "required_run_files": [
      "run.yaml",
      "capture_refs.yaml",
      "artifacts/intake_gate.yaml",
      "artifacts/runtime_session.yaml",
      "artifacts/runtime_snapshot.yaml",
      "artifacts/ownership_lease.yaml",
      "artifacts/runtime_failure.yaml",
      "notes/hypothesis_board.yaml",
      "reports/report.md",
      "reports/visual_report.html"
    ],
    "required_session_files": [
      "session_evidence.yaml",
      "skeptic_signoff.yaml",
      "action_chain.jsonl"
    ],
    "required_final_refs": [
      "BugCard/BugFull reference or DEBUGGER_FINAL_VERDICT"
    ],
    "run_compliance_artifact": "artifacts/run_compliance.yaml",
    "freeze_state_artifact": "artifacts/freeze_state.yaml",
    "finalization_receipt_artifact": "artifacts/finalization_receipt.yaml",
    "write_scope_paths": {
      "workspace_control": "workspace/cases/<case_id>/",
      "workspace_notes": "workspace/cases/<case_id>/runs/<run_id>/notes/",
      "session_signoff": "common/knowledge/library/sessions/<session_id>/skeptic_signoff.yaml",
      "workspace_reports": "workspace/cases/<case_id>/runs/<run_id>/reports/",
      "session_artifacts": "common/knowledge/library/sessions/<session_id>/",
      "knowledge_library": "common/knowledge/library/"
    }
  },
  "platforms": {
    "claude-code": {"coordination_mode": "staged_handoff", "required_surfaces": ["agents", "skills", "hooks", "mcp"], "workflow_required": false, "enforcement_mode": "shared_harness", "enforcement_tier": "native-hooks", "public_entrypoints": ["rdc-debugger"], "requires_run_compliance_artifact": true},
    "code-buddy": {"coordination_mode": "staged_handoff", "required_surfaces": ["agents", "skills", "hooks", "mcp"], "workflow_required": false, "enforcement_mode": "shared_harness", "enforcement_tier": "pseudo-hooks", "public_entrypoints": ["rdc-debugger"], "requires_run_compliance_artifact": true},
    "codex": {"coordination_mode": "staged_handoff", "required_surfaces": ["agents", "skills", "mcp"], "workflow_required": false, "enforcement_mode": "shared_harness", "enforcement_tier": "pseudo-hooks", "public_entrypoints": ["rdc-debugger"], "requires_run_compliance_artifact": true},
    "copilot-cli": {"coordination_mode": "staged_handoff", "required_surfaces": ["agents", "skills", "hooks", "mcp"], "workflow_required": false, "enforcement_mode": "shared_harness", "enforcement_tier": "native-hooks", "public_entrypoints": ["rdc-debugger"], "requires_run_compliance_artifact": true}
  }
}