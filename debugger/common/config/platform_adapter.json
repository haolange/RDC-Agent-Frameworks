{
  "schema_version": 3,
  "description": "Framework-to-tools binding. paths.tools_source_root is fixed to the package-local directory 'tools'; it is a source payload only, while live runtime is staged into a daemon-owned worker cache.",
  "paths": {
    "tools_source_root": "tools"
  },
  "runtime": {
    "mode": "worker_staged"
  },
  "validation": {
    "mode": "hard_fail",
    "required_paths": [
      "README.md",
      "docs/tools.md",
      "docs/session-model.md",
      "docs/agent-model.md",
      "spec/tool_catalog.json",
      "rdx.bat",
      "binaries/windows/x64/manifest.runtime.json",
      "binaries/windows/x64/python/python.exe"
    ]
  },
  "cli": {
    "launcher": "rdx.bat",
    "reference_doc": "debugger\\docs\\cli-mode-reference.md"
  }
}
