{
  "schema_version": 2,
  "description": "Framework-to-tools binding. tools_root is fixed to the relative path 'tools'; users must copy RDC-Agent-Tools into the platform root tools/ directory before use.",
  "paths": {
    "tools_root": "tools"
  },
  "validation": {
    "mode": "hard_fail",
    "required_paths": [
      "README.md",
      "docs/tools.md",
      "docs/session-model.md",
      "docs/agent-model.md",
      "spec/tool_catalog.json"
    ]
  },
  "mcp": {
    "server_name": "renderdoc-platform-mcp",
    "launch_command": [
      "python",
      "mcp/run_mcp.py"
    ]
  },
  "cli": {
    "launcher": "rdx.bat",
    "reference_doc": "debugger\\docs\\cli-mode-reference.md"
  }
}
